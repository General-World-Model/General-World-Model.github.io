---
interface Props {
  currentPage?: string;
}
const { currentPage = "/" } = Astro.props;

const links = [
  { href: "/#overview", label: "Overview" },
  { href: "/cfp", label: "Call for Talks" },
  { href: "/#organizers", label: "Organizers" },
  { href: "/speakers", label: "Speakers" },
  { href: "/news", label: "News" },
  { href: "/#sponsors", label: "Sponsors" },
];
---

<header class="topbar">
  <div class="nav-container">
    <nav class="nav-island">
      <a class="brand" href="/" aria-label="General World Model home">
        <span class="brand-mark" aria-hidden="true">
          <span class="brand-mark-core"></span>
          <span class="brand-mark-ring"></span>
          <span class="brand-mark-halo"></span>
        </span>
        <span class="brand-text">General World Model</span>
      </a>

      <button class="nav-toggle" aria-label="Open menu" aria-expanded="false">
        <span></span><span></span><span></span>
      </button>

      <div class="nav-links" role="navigation" aria-label="Primary">
        {links.map((link) => (
          <a
            href={link.href}
            class:list={[{ active: currentPage === link.href }]}
          >
            {link.label}
          </a>
        ))}
      </div>
    </nav>

    <a href="/#contact" class="contact-pill-standalone shadow-glow">Contact</a>
  </div>
</header>

<style>
  /* ═══════ DYNAMIC ISLAND LAYOUT ═══════ */
  .topbar {
    position: fixed;
    top: 16px;
    left: 0;
    right: 0;
    z-index: 100;
    display: flex;
    justify-content: center;
    pointer-events: none; /* Allow clicks through empty space */
  }

  .nav-container {
    display: flex;
    align-items: center;
    gap: 1.25rem;
    pointer-events: auto; /* Re-enable for actual interative parts */
    padding: 0 1.5rem;
  }

  /* The actual "Island" with border */
  .nav-island {
    display: flex;
    align-items: center;
    gap: 1.5rem;
    padding: 0 1.75rem;
    height: 56px;
    border-radius: 50px;
    background: rgba(10, 14, 26, 0.55);
    backdrop-filter: blur(28px) saturate(1.6);
    -webkit-backdrop-filter: blur(28px) saturate(1.6);
    border: 1px solid rgba(255, 255, 255, 0.08);
    box-shadow:
      0 12px 40px rgba(0, 0, 0, 0.45),
      0 1.5px 0 rgba(255, 255, 255, 0.04) inset;
    transition: all 0.4s cubic-bezier(0.16, 1, 0.3, 1);
  }

  .nav-island:hover {
    background: rgba(10, 14, 26, 0.65);
    border-color: rgba(255, 255, 255, 0.12);
    box-shadow:
      0 16px 48px rgba(0, 0, 0, 0.5),
      0 1.5px 0 rgba(255, 255, 255, 0.06) inset;
  }

  /* Separate Contact Pill */
  .contact-pill-standalone {
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 0 1.5rem;
    height: 48px; /* Slightly shorter than island for hierarchy */
    border-radius: 50px;
    background: rgba(10, 14, 26, 0.5);
    backdrop-filter: blur(24px);
    -webkit-backdrop-filter: blur(24px);
    border: 1px solid rgba(79, 164, 212, 0.4);
    color: var(--accent-bright);
    font-weight: 600;
    font-size: 0.88rem;
    text-decoration: none;
    transition: all 0.35s var(--transition);
    margin-left: 0.5rem; /* Additional separation */
  }

  .contact-pill-standalone:hover {
    background: var(--accent);
    color: #fff;
    border-color: var(--accent);
    box-shadow: 0 0 24px var(--accent-glow);
    transform: translateY(-2px);
  }

  /* Brand */
  .brand {
    display: flex;
    align-items: center;
    gap: 0.65rem;
    text-decoration: none;
    color: var(--text);
    flex-shrink: 0;
  }

  .brand-mark {
    position: relative;
    width: 28px;
    height: 28px;
  }

  .brand-mark-core {
    position: absolute;
    inset: 4px;
    border-radius: 50%;
    background: radial-gradient(circle at 38% 35%, #a7dcf5 0%, var(--accent) 40%, #1a4462 100%);
    box-shadow: 0 0 12px rgba(79, 164, 212, 0.6);
    z-index: 2;
  }

  .brand-mark-ring {
    position: absolute;
    inset: 1px;
    border-radius: 50%;
    border: 1.5px solid rgba(110, 192, 236, 0.35);
    z-index: 3;
    animation: ring-breathe 4s ease-in-out infinite;
  }

  .brand-mark-halo {
    position: absolute;
    inset: -6px;
    border-radius: 50%;
    background: radial-gradient(circle, rgba(79, 164, 212, 0.25) 0%, transparent 70%);
    z-index: 1;
    animation: halo-pulse 5s ease-in-out infinite alternate;
  }

  @keyframes ring-breathe {
    0%, 100% { transform: scale(1); opacity: 0.6; }
    50% { transform: scale(1.08); opacity: 1; }
  }

  @keyframes halo-pulse {
    0% { transform: scale(0.9); opacity: 0.4; }
    100% { transform: scale(1.3); opacity: 0.8; }
  }

  .brand-text {
    font-family: var(--font-display);
    font-size: 1.1rem;
    font-weight: 500;
    letter-spacing: 0.01em;
  }

  /* Links */
  .nav-links {
    display: flex;
    align-items: center;
    gap: 0.25rem;
  }

  .nav-links a {
    padding: 0.35rem 0.85rem;
    font-size: 0.88rem;
    font-weight: 500;
    color: var(--text-secondary);
    border-radius: 20px;
    text-decoration: none;
    transition: all var(--transition);
    white-space: nowrap;
  }

  .nav-links a:hover,
  .nav-links a.active {
    color: var(--accent-bright);
    background: rgba(255, 255, 255, 0.06);
  }

  /* Mobile toggle */
  .nav-toggle {
    display: none;
    flex-direction: column;
    gap: 5px;
    background: none;
    border: none;
    cursor: pointer;
    padding: 6px;
    z-index: 110;
  }
  .nav-toggle span {
    width: 22px;
    height: 2px;
    background: var(--text);
    border-radius: 2px;
    transition: all 0.3s;
  }

  @media (max-width: 900px) {
    .nav-container {
      width: 100%;
      justify-content: center;
    }

    .nav-island {
      flex: 1;
      justify-content: space-between;
      gap: 1rem;
      padding: 0 1.25rem;
    }

    .contact-pill-standalone {
      display: none; /* Hide on mobile island, put in menu */
    }

    .nav-toggle {
      display: flex;
    }

    .nav-links {
      position: fixed;
      top: 0;
      right: 0;
      width: min(320px, 85vw);
      height: 100vh;
      flex-direction: column;
      align-items: flex-start;
      gap: 0.25rem;
      padding: 6rem 2rem 2rem;
      background: rgba(10, 14, 26, 0.98);
      backdrop-filter: blur(24px);
      border-left: 1px solid var(--glass-border);
      transform: translateX(100%);
      transition: transform 0.4s cubic-bezier(0.16, 1, 0.3, 1);
    }

    .nav-links.open { transform: translateX(0); }

    .nav-links a {
      font-size: 1.05rem;
      padding: 0.8rem 1rem;
      width: 100%;
    }
  }
</style>

<script>
  const toggle = document.querySelector(".nav-toggle");
  const links = document.querySelector(".nav-links");
  if (toggle && links) {
    toggle.addEventListener("click", () => {
      const isOpen = toggle.getAttribute("aria-expanded") === "true";
      toggle.setAttribute("aria-expanded", String(!isOpen));
      links.classList.toggle("open");
    });
    // Close on link click (mobile)
    links.querySelectorAll("a").forEach((a) => {
      a.addEventListener("click", () => {
        toggle.setAttribute("aria-expanded", "false");
        links.classList.remove("open");
      });
    });
  }
</script>
